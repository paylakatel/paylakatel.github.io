%;margin:0;vertical-align:middle;position:absolute;top:0;left:0;box-shadow:inset 0px 0px 0px 400px white;\" alt=\"Figure 6\" title src=\"/static/cc6051c45f961675c51cbceedce71e50/81124/figure_6.png\" srcset=\"/static/cc6051c45f961675c51cbceedce71e50/bcdc2/figure_6.png 125w,\n/static/cc6051c45f961675c51cbceedce71e50/812ad/figure_6.png 250w,\n/static/cc6051c45f961675c51cbceedce71e50/81124/figure_6.png 500w,\n/static/cc6051c45f961675c51cbceedce71e50/2aa1d/figure_6.png 750w,\n/static/cc6051c45f961675c51cbceedce71e50/1ec8c/figure_6.png 1000w,\n/static/cc6051c45f961675c51cbceedce71e50/346cf/figure_6.png 1500w,\n/static/cc6051c45f961675c51cbceedce71e50/ac1d9/figure_6.png 1747w\" sizes=\"(max-width: 500px) 100vw, 500px\">\n  </span>\n  </a>\n</div>\n<div></div></div>","frontmatter":{"title":"Extraction in Ghana"}}},"pageContext":{"slug":"/projects/extraction-in-ghana/"}}